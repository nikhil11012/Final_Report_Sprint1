<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CARS</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Crime.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark sticky-top" style="background: linear-gradient(135deg, #0f2027, #203a43, #2c5364); backdrop-filter: blur(10px); box-shadow: 0 4px 30px rgba(0,0,0,0.3);">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold fs-4 d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-incognito" style="font-size: 1.6rem; color: #4fc3f7;"></i>
                    <span style="letter-spacing: 1px;">The Detectives</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav gap-1 align-items-center">
                        <li class="nav-item">
                            <a class="nav-link nav-icon-link" asp-area="" asp-controller="Home" asp-action="Index" title="Home" data-bs-toggle="tooltip" data-bs-placement="bottom">
                                <i class="bi bi-house-fill"></i>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link nav-icon-link" href="#services" title="Services" data-bs-toggle="tooltip" data-bs-placement="bottom">
                                <i class="bi bi-grid-3x3-gap-fill"></i>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-icon-link" href="#workflow" title="Workflow" data-bs-toggle="tooltip" data-bs-placement="bottom">
                                <i class="bi bi-diagram-3-fill"></i>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-icon-link" asp-controller="Report" asp-action="Index" title="Reports" data-bs-toggle="tooltip" data-bs-placement="bottom">
                                <i class="bi bi-file-earmark-bar-graph-fill"></i>
                            </a>
                        </li>
                        <li class="nav-item ms-2">
                            <a class="nav-link nav-icon-link" asp-controller="Incident" asp-action="Index" title="Incidents" data-bs-toggle="tooltip" data-bs-placement="bottom">
                                <i class="bi bi-exclamation-triangle-fill"></i>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-icon-link" asp-controller="Case" asp-action="Index" title="Cases" data-bs-toggle="tooltip" data-bs-placement="bottom">
                                <i class="bi bi-folder-fill"></i>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-icon-link" asp-controller="Officers" asp-action="Index" title="Officers" data-bs-toggle="tooltip" data-bs-placement="bottom">
                                <i class="bi bi-person-badge-fill"></i>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main id="main-content" role="main" class="pb-3" style="min-height: 400px; transition: opacity 0.3s ease;">
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <footer class="footer-section">
        <div class="container text-center">
            <p class="mb-1">&copy; 2026 — Crime Analysis & Reporting System</p>
            <p class="mb-0" style="font-size: 0.8rem; opacity: 0.7;">
                <i class="bi bi-code-slash"></i> Built with <i class="bi bi-heart-fill" style="color: #e53935;"></i> by
                <strong>Aakash</strong> &bull; <strong>Ankit</strong> &bull; <strong>Ayan</strong> &bull; <strong>Nikhil</strong> &bull; <strong>Diksha</strong>
            </p>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function () {
            // Auto-dismiss alerts
            setTimeout(function () {
                $(".alert").alert('close');
            }, 3000);

            // Initialize Bootstrap tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function (el) {
                return new bootstrap.Tooltip(el);
            });

            // Smooth scrolling for anchor links
            $('a[href^="#"]').on('click', function (e) {
                var target = $(this.getAttribute('href'));
                if (target.length) {
                    e.preventDefault();
                    $('html, body').animate({ scrollTop: target.offset().top - 70 }, 600);
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
