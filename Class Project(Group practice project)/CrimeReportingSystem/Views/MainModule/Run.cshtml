@model List<string>

@{
    ViewData["Title"] = "MainModule - Service Method Tests";
}

<h2>MainModule — Trigger All Service Methods</h2>
<p class="text-muted">This page calls every method in CrimeService and shows the results below.</p>

<hr />

<div class="card">
    <div class="card-body" style="background-color: #1e1e1e; color: #d4d4d4; font-family: 'Consolas', monospace; font-size: 14px; border-radius: 8px;">
        @foreach (var line in Model)
        {
            @if (line.StartsWith("="))
            {
                <div style="color: #569cd6; font-weight: bold; margin-top: 10px;">@line</div>
            }
            else if (line.StartsWith("✅"))
            {
                <div style="color: #4ec9b0;">@line</div>
            }
            else if (line.StartsWith("❌"))
            {
                <div style="color: #f44747;">@line</div>
            }
            else if (line.StartsWith("⚠️"))
            {
                <div style="color: #dcdcaa;">@line</div>
            }
            else
            {
                <div>@line</div>
            }
        }
    </div>
</div>

<div class="mt-3">
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Back to Home</a>
</div>
