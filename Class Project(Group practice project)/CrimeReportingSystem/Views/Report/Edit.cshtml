@model Crime.Models.Report

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Report</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ReportId" />
            <div class="form-group">
                <label asp-for="ReportDate" class="control-label"></label>
                <input asp-for="ReportDate" class="form-control" />
                <span asp-validation-for="ReportDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ReportDetails" class="control-label"></label>
                <input asp-for="ReportDetails" class="form-control" />
                <span asp-validation-for="ReportDetails" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" class="form-select">
                    <option value="Draft">Draft</option>
                    <option value="Finalized">Finalized</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="IncidentId" class="control-label"></label>
                <select asp-for="IncidentId" class="form-control" asp-items="ViewBag.IncidentId"></select>
                <span asp-validation-for="IncidentId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ReportingOfficerId" class="control-label"></label>
                <select asp-for="ReportingOfficerId" class="form-control" asp-items="ViewBag.ReportingOfficerId"></select>
                <span asp-validation-for="ReportingOfficerId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
