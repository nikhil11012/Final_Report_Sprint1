@model IEnumerable<FoodDeliveryMVC.Models.Sale>

@{
    ViewData["Title"] = "Orders";
}

<h1>Order History</h1>

<table class="table">
    <thead>
        <tr>
            <th>Order ID</th>
            <th>Date</th>
            <th>Customer</th>
            <th>Total Amount</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.SaleId</td>
                <td>@item.Date</td>
                <td>@item.CustomerId</td>
                <td>@item.TotalAmount</td>
                <td>@item.Status</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.SaleId" class="btn btn-sm btn-info">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.SaleId" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
